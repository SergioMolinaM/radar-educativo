# ===========================================
# Radar Educativo - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Database
DATABASE_URL=postgresql://radar:YOUR_SECURE_PASSWORD@localhost:5432/radar_edu
DB_PASSWORD=YOUR_SECURE_PASSWORD

# Security
SECRET_KEY=generate-a-random-64-char-string-here

# Data paths
RAW_DATA_PATH=data/raw
STAGING_DATA_PATH=data/staging
PROCESSED_DATA_PATH=data/processed

# Logging
LOG_LEVEL=INFO

# External APIs
MERCADO_PUBLICO_TICKET=your_mercado_publico_api_ticket
